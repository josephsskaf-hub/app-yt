# Copy to .env.local and fill in. Never commit .env.local.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Stripe Publishable key (pk_live_... or pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price ID for the $5/month seller plan (price_...)
VITE_STRIPE_PRICE_ID=price_xxx

# --- The following are used inside Supabase Edge Functions, set them as
# --- secrets via: supabase secrets set NAME=value
#
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# APP_URL=https://your-domain.com
